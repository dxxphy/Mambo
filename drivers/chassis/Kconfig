# Chassis driver configuration options

# Copyright (c) 2025 ttwards <12411711@mail.sustech.edu.cn>
# SPDX-License-Identifier: Apache-2.0

menuconfig CHASSIS
    bool "Chassis drivers"
	select WHEEL
    help
      Enable support for chassis.

if CHASSIS

module = CHASSIS
module-str = CHASSIS
source "subsys/logging/Kconfig.template.log_config"

config CHASSIS_LOG_LEVEL
    int "Motor log level"
    default 4
    help
      The log level of chassis driver

config CHASSIS_INIT_PRIORITY
	int "Chassis init priority"
	default 90
	help
	  The init priority of chassis driver

config CHASSIS_LATENCY_TRACE
	bool "Trace chassis control latency"
	default n
	help
	  Record and log chassis command age, timer wakeup latency and resolve
	  duration. Enable this only when chassis latency measurement is needed.

config CHASSIS_LATENCY_TRACE_LOG_INTERVAL_MS
	int "Chassis latency trace log interval in milliseconds"
	default 1000
	depends on CHASSIS_LATENCY_TRACE
	help
	  Minimum interval between repeated chassis latency trace logs.

endif
